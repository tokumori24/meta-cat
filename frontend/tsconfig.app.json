{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2024",
    "types": ["vitest/globals"]
  },
  "include": ["src"]
}
