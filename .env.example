# =============================================================================
# 環境変数サンプル。`cp .env.example .env` してから値を編集してください。
# docker-compose が自動で読み込み、各サービスに注入します。
# =============================================================================

# --- LiveKit 認証情報 ---------------------------------------------------------
# backend がトークン署名に使用し、livekit サーバが検証に使用します（両者一致が必須）。
# livekit を `--dev` で起動している間は devkey / secret 固定です。
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- LiveKit メディア到達先 ---------------------------------------------------
# WebRTC メディアの中継先 IP。クライアントがここへ接続できる必要があります。
#   ローカル開発: 127.0.0.1
#   EC2 本番    : EC2 のパブリック IP（例: 13.112.xx.xx）
LIVEKIT_NODE_IP=127.0.0.1

# --- ブラウザが接続する URL（VITE_ プレフィックス必須）------------------------
# フロントはブラウザ内で動くため、必ず「外部から到達できる」アドレスを指定。
#   ローカル開発  : 下記の localhost のまま
#   EC2 (HTTP直)  : ws://<EC2のIP>:3000 / ws://<EC2のIP>:7880 / http://<EC2のIP>:3000/api/livekit/token
#   EC2 (HTTPS)   : wss://<domain> / wss://<domain>/livekit / https://<domain>/api/livekit/token
#                   ※ マイク(getUserMedia)は HTTPS でないと使えないため本番は wss/https 推奨
VITE_BACKEND_WS_URL=ws://localhost:3000
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_LIVEKIT_TOKEN_API_URL=http://localhost:3000/api/livekit/token

# --- 本番(EC2 + Caddy) 用ドメイン -------------------------------------------
# Caddy が HTTPS を終端するドメイン。ローカル開発(docker-compose.yml)では不要。
# ドメインを持っていない場合は sslip.io が使えます（下記 補足参照）:
#   APP_DOMAIN=<EC2のIPをハイフン化>.sslip.io  例: 13-112-1-1.sslip.io
#   LIVEKIT_DOMAIN=livekit-<同上>.sslip.io      例: livekit-13-112-1-1.sslip.io
APP_DOMAIN=demo.example.com
LIVEKIT_DOMAIN=livekit.example.com

